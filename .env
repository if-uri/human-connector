# human:// connector surface — configuration
# Copy this file to .env and adjust values.

# Network
URIRUN_HUMAN_PORT=8797
URIRUN_HUMAN_HOST=0.0.0.0

# Default node shown in the worker UI
URIRUN_HUMAN_NODE=cell-a

# LAN IP for the QR code (set to 'auto' to detect automatically)
URIRUN_HUMAN_LAN_IP=auto
