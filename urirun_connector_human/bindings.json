{
  "version": "urirun.bindings.v2",
  "label": "human://{node} \u2014 human-in-the-loop task connector",
  "bindings": {
    "human://{node}/task/create": {
      "uri": "human://{node}/task/create",
      "kind": "command",
      "adapter": "local-function",
      "meta": {
        "connector": "human",
        "label": "Post a human task (\u2192 pending + next:await)"
      }
    },
    "human://{node}/task/poll": {
      "uri": "human://{node}/task/poll",
      "kind": "query",
      "adapter": "local-function",
      "meta": {
        "connector": "human",
        "label": "Poll task state (pending|done|declined)"
      }
    },
    "human://{node}/task/resolve": {
      "uri": "human://{node}/task/resolve",
      "kind": "command",
      "adapter": "local-function",
      "meta": {
        "connector": "human",
        "label": "Worker submits task outcome"
      }
    },
    "human://{node}/task/cancel": {
      "uri": "human://{node}/task/cancel",
      "kind": "command",
      "adapter": "local-function",
      "meta": {
        "connector": "human",
        "label": "Cancel a pending task (reversibility)"
      }
    },
    "human://{node}/grant/satisfy": {
      "uri": "human://{node}/grant/satisfy",
      "kind": "command",
      "adapter": "local-function",
      "meta": {
        "connector": "human",
        "label": "Per-env grant (Phase 6 precondition provider)"
      }
    }
  }
}